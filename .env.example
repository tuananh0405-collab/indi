# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ──────────────────────────────────────────────
# MongoDB
# ──────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/indi-ticketing

# ──────────────────────────────────────────────
# Admin Auth (simple static key)
# ──────────────────────────────────────────────
ADMIN_API_KEY=your-super-secret-admin-key-here

# ──────────────────────────────────────────────
# PayOS
# ──────────────────────────────────────────────
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key

# ──────────────────────────────────────────────
# Email (SMTP — Brevo / Resend / Gmail)
# ──────────────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM_NAME=INDI Event
SMTP_FROM_EMAIL=noreply@indi-event.com

# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
TICKET_CAPACITY=400
ORDER_TTL_MINUTES=10
FRONTEND_URL=http://localhost:5173
